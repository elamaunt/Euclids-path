/-
  Collatz как ОСОБЫЙ СЛУЧАЙ вечного двигателя Евклида — структурные факты (core Lean, без Mathlib).
  Разбор: prose/55_Collatz.md. Числа: tools/collatz_engine_harness.py.

  Двигатель Евклида: КАЖДЫЙ шаг — строгий спуск `A·h' < h` (A≥1) ⟹ `no_infinite_descent` ⟹ ВСЕГДА
  останавливается; высота `StrictAnti` ⟹ не возвращается (нет цикла).

  Collatz (ускоренная карта `T`): чётный шаг `n↦n/2` — спуск РОВНО на 2 (край, не строгий при A=2);
  нечётный шаг `n↦(3n+1)/2` — ВОСХОЖДЕНИЕ (инъекция топлива «+1»). Значит Collatz НЕ удовлетворяет
  предпосылке строгого спуска — поэтому его остановка ОТКРЫТА (в отличие от двигателя Евклида).

  Самодостаточен (core Lean, без import): дубли `T` с прочими Collatz-файлами намеренны.
-/

namespace EuclidsPath.Collatz.Engine

/-- Ускоренная карта Коллатца: чётное `n↦n/2`, нечётное `n↦(3n+1)/2` (вынужденное деление вложено). -/
def T (n : Nat) : Nat := if n % 2 = 0 then n / 2 else (3 * n + 1) / 2

/-- **Чётный шаг — спуск РОВНО на 2** (`2·(n/2)=n`): это КРАЙ спуска двигателя (`A·h'=h`, не `<`).
    При любом `A>2` чётный шаг не был бы спуском; при `A=2` — ровно граница. -/
theorem even_marginal (n : Nat) (h : n % 2 = 0) : 2 * (n / 2) = n := by omega

/-- **Нечётный шаг — ВОСХОЖДЕНИЕ сырого значения («+1» = топливо):** `n < 3n+1`. -/
theorem odd_raw_ascends (n : Nat) : n < 3 * n + 1 := by omega

/-- **Нечётный ускоренный шаг тоже поднимается:** `(3n+1)/2 > n` при `n ≥ 1`. Топливо впрыснуто. -/
theorem odd_accel_ascends (n : Nat) (h1 : 1 ≤ n) (h : n % 2 = 1) : n < (3 * n + 1) / 2 := by omega

/-- **Collatz НЕ строгий двигатель:** на нечётном `n≥1` шаг НЕ спуск (`¬ (T n < n)`).
    Значит `no_infinite_descent` к Collatz НЕ применима — остановка не гарантирована законом. -/
theorem not_descent_on_odd (n : Nat) (h1 : 1 ≤ n) (h : n % 2 = 1) : ¬ (T n < n) := by
  unfold T; rw [if_neg (show ¬ (n % 2 = 0) by omega)]; omega

/-- **Баланс топлива:** одно умножение на 3 нельзя погасить ОДНИМ делением (`2 < 3`), нужно ≥ двух
    (`3 ≤ 4 = 2²`). Поэтому для спуска нужно halvings/triplings > log₂3 ≈ 1.585 (численно ≈ 2.016). -/
theorem one_tripling_needs_two_halvings : ¬ (3 ≤ 2) ∧ (3 ≤ 2 * 2) := by omega

/-- **Тривиальный цикл = состояние ОСТАНОВКИ двигателя:** `1 → 2 → 1` (поглощающий минимум).
    Любой ЧУЖОЙ цикл был бы вечным двигателем (возврат), запрещённым `engine_never_returns`
    ТОЛЬКО при строгом спуске — а его у Collatz нет, потому отсутствие чужих циклов ОТКРЫТО. -/
theorem trivial_halt_cycle : T 1 = 2 ∧ T 2 = 1 := by decide

end EuclidsPath.Collatz.Engine

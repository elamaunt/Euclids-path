/-! ### The fused Bool checker -/

/-- One Bool pass of the clean test at center `m` over the clock list `qs`
    (for `qs` covering the primes `5 ≤ q ≤ A` this decides `Clean A m` from above). -/
def cleanListB (qs : List ℕ) (m : ℕ) : Bool :=
  qs.all fun q => (!((6 * m - 1) % q == 0)) && (!((6 * m + 1) % q == 0))

/-- The chain fold: `prev` is the previous witness, the terminal case checks the wrap
    inequality `head + P ≤ last + L` against the chain head carried through the fold.
    The recursive call sits in tail position of the `&&` chain, so kernel `whnf` evaluates
    the list in one sequential short-circuiting pass — the reduction never stacks a growing
    term (kernel memory still grows with list length through its caches; measured numbers
    at the `A = 19` theorem below). -/
def chainB (qs : List ℕ) (L P head : ℕ) : ℕ → List ℕ → Bool
  | prev, [] => Nat.ble (head + P) (prev + L)
  | prev, x :: xs =>
      Nat.blt prev x && Nat.ble x (prev + L) && Nat.ble x P && cleanListB qs x &&
        chainB qs L P head x xs

/-- The full witness-chain check: head bounds (`1 ≤ x ≤ L`, `x ≤ P`), head cleanliness,
    then the fused fold over the tail. -/
def witnessChainB (qs : List ℕ) (L P : ℕ) : List ℕ → Bool
  | [] => false
  | x :: xs =>
      Nat.ble 1 x && Nat.ble x L && Nat.ble x P && cleanListB qs x && chainB qs L P x x xs

/-! ### Soundness: from the Bool fold back to the Prop chain (one direction only) -/

theorem cleanListB_correct {qs : List ℕ} {m : ℕ} (h : cleanListB qs m = true) :
    ∀ q ∈ qs, ¬ q ∣ (6 * m - 1) ∧ ¬ q ∣ (6 * m + 1) := by
  simp only [cleanListB, List.all_eq_true, Bool.and_eq_true, Bool.not_eq_true'] at h
  intro q hq
  obtain ⟨h1, h2⟩ := h q hq
  refine ⟨fun hd => ?_, fun hd => ?_⟩
  · rw [Nat.mod_eq_zero_of_dvd hd] at h1
    simp at h1
  · rw [Nat.mod_eq_zero_of_dvd hd] at h2
    simp at h2

/-- The Bool pass plus prime coverage of the clock list yields `Clean`.  The clocks `2, 3`
    are never active on the wings `6m ∓ 1` (parity and mod-3 arithmetic — `omega` closes
    both from the literal divisibilities). -/
theorem clean_of_cleanListB {A m : ℕ} {qs : List ℕ} (hm : 1 ≤ m)
    (hcov : ∀ q : ℕ, q.Prime → 5 ≤ q → q ≤ A → q ∈ qs)
    (h : cleanListB qs m = true) : Clean A m := by
  intro q hq hqA hor
  rcases Nat.lt_or_ge q 5 with h5 | h5
  · have h2 := hq.two_le
    interval_cases q
    · rcases hor with hd | hd <;> omega
    · rcases hor with hd | hd <;> omega
    · exact absurd hq (by norm_num)
  · obtain ⟨hminus, hplus⟩ := cleanListB_correct h q (hcov q hq h5 hqA)
    rcases hor with hd | hd
    · exact hminus hd
    · exact hplus hd

/-- Re-proved locally (private in `Step00ExtremalGapGeometry`). -/
private theorem getLastI_cons_cons (x y : ℕ) (t : List ℕ) :
    (x :: y :: t).getLastI = (y :: t).getLastI := by
  rw [List.getLastI_eq_getLast?_getD, List.getLastI_eq_getLast?_getD,
    List.getLast?_cons_cons]

/-- The induction engine: one `chainB` run certifies the chain shape, the per-witness
    facts (cleanliness, strict lower bound by `prev`, upper bound `P`) and the wrap
    inequality — everything `WitnessChain` needs beyond the head conjuncts. -/
private theorem chainB_spec {qs : List ℕ} {L P head : ℕ} :
    ∀ {xs : List ℕ} {prev : ℕ}, chainB qs L P head prev xs = true →
      (prev :: xs).IsChain (fun a b => a < b ∧ b ≤ a + L) ∧
        (∀ m ∈ xs, cleanListB qs m = true ∧ prev < m ∧ m ≤ P) ∧
        head + P ≤ (prev :: xs).getLastI + L := by
  intro xs
  induction xs with
  | nil =>
    intro prev h
    simp only [chainB, Nat.ble_eq] at h
    exact ⟨List.isChain_singleton prev, by simp, h⟩
  | cons x rest ih =>
    intro prev h
    simp only [chainB, Bool.and_eq_true, Nat.ble_eq, Nat.blt_eq] at h
    obtain ⟨⟨⟨⟨h1, h2⟩, h3⟩, h4⟩, h5⟩ := h
    obtain ⟨ihchain, ihmem, ihwrap⟩ := ih h5
    refine ⟨List.isChain_cons_cons.mpr ⟨⟨h1, h2⟩, ihchain⟩, ?_, ?_⟩
    · intro m hm
      rcases List.mem_cons.mp hm with rfl | hm'
      · exact ⟨h4, h1, h3⟩
      · obtain ⟨hc, hlt, hP⟩ := ihmem m hm'
        exact ⟨hc, by omega, hP⟩
    · rw [getLastI_cons_cons]
      exact ihwrap

/-- **Soundness of the fused fold**: one `witnessChainB` run plus prime coverage of the
    clock list assembles the full Prop-level `WitnessChain`.  One-directional by design —
    the fold is a checker, completeness is never used. -/
theorem witnessChainB_correct {A L P : ℕ} {qs c : List ℕ}
    (hcov : ∀ q : ℕ, q.Prime → 5 ≤ q → q ≤ A → q ∈ qs)
    (h : witnessChainB qs L P c = true) : WitnessChain A L P c := by
  cases c with
  | nil => simp [witnessChainB] at h
  | cons x xs =>
    simp only [witnessChainB, Bool.and_eq_true, Nat.ble_eq] at h
    obtain ⟨⟨⟨⟨hx1, hxL⟩, hxP⟩, hxclean⟩, hrest⟩ := h
    obtain ⟨hchain, hmem, hwrap⟩ := chainB_spec hrest
    refine ⟨List.cons_ne_nil x xs, hchain, ?_, ?_, hwrap, hx1, hxL⟩
    · intro m hm
      rcases List.mem_cons.mp hm with rfl | hm'
      · exact clean_of_cleanListB hx1 hcov hxclean
      · obtain ⟨hc, hlt, hP⟩ := hmem m hm'
        exact clean_of_cleanListB (by omega) hcov hc
    · intro m hm
      rcases List.mem_cons.mp hm with rfl | hm'
      · exact ⟨hx1, hxP⟩
      · obtain ⟨hc, hlt, hP⟩ := hmem m hm'
        exact ⟨by omega, hP⟩

/-! ### Calibration gate: the `A = 17` chain through the fused fold

Measured on the reference machine (32 GB, Lean v4.31): this theorem costs **~1.3 s** net
wall time (isolated `lake env lean` delta over the bare import), against **69 s** for the
Prop-level `witnessChain_17` of `Step00ExtremalGapGeometry` (elaborator `decide`) at the
same scale.  The elaborator-vs-kernel split was also measured on the UNCHANGED Prop
statement (scratch run, not shipped):

    theorem witnessChain_17' : WitnessChain 17 41 85085 witnessList17 := by decide +kernel

lands in **~6 s** net — so switching the evaluator from the elaborator to the kernel buys
~11x on the same Prop statement, and the fused Bool fold buys another ~5x on top of the
kernel switch.  Registered gate (60 s / 4 GB): GREEN with two orders of margin — the
`A = 19` attempt below is sanctioned. -/

set_option maxRecDepth 100000 in
/-- The 2193-witness chain of `Step00ExtremalGapGeometry` re-verified through the fused Bool
    fold by kernel reduction (`decide +kernel`, ~1.3 s — see the section comment). -/
theorem witnessChainB_17 :
    witnessChainB [5, 7, 11, 13, 17] 41 85085 witnessList17 = true := by
  decide +kernel


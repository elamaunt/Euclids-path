/-
  Collatz как двигатель на ОГРАНИЧЕННОМ топливе — анализ гипотезы.
  Разбор: prose/E_Collatz.md. Числа: tools/collatz_fuel_harness.py.

  Вопрос: Collatz = двигатель на ограниченном топливе?
  Ответ (числа + алгебра): топливо ОГРАНИЧЕНО (энергия ~13.3 вдоль траектории), дрейф СЖИМАЮЩИЙ
  (−0.21/шаг), НО монотонной высоты НЕТ даже после сжатия odd-блоков (odd→odd при k=1 растит).
  Поэтому наш EPMI (требует СТРОГОГО спуска высоты каждый шаг) к Collatz НЕприменим — это точная
  причина открытости: только СРЕДНИЙ (не монотонный) спуск.

  Здесь фиксируется алгебра разрыва (core Lean, без Mathlib; самодостаточен).
-/

namespace EuclidsPath.Collatz.Fuel

-- Сжатый odd→odd шаг: `n` нечётное ↦ `(3n+1)/2^k`, где `2^k ‖ 3n+1`. Высота `log₂` меняется на
-- `≈ log₂3 − k`. Падает при `k ≥ 2`, РАСТЁТ при `k = 1`.

/-- **k=1 случай: высота растёт (нет монотонности).** Если `3n+1 = 2·m` с `m` нечётным
    (т.е. `k=1`), то `m = (3n+1)/2 > n` для `n ≥ 1`: сжатый odd-шаг УВЕЛИЧИВАЕТ значение.
    Это случай `n ≡ 1 (mod 4)` (≈50%), и он ломает монотонность любой `log₂`-высоты. -/
theorem k1_step_grows (n : Nat) (h1 : 1 ≤ n) (hk1 : (3 * n + 1) % 4 = 2) :
    n < (3 * n + 1) / 2 := by
  omega

/-- **k≥2 случай: высота падает.** Если `4 ∣ 3n+1` (`k≥2`), то `(3n+1)/4 < n` для `n ≥ 2`. -/
theorem k2_step_drops (n : Nat) (h2 : 2 ≤ n) (hk2 : (3 * n + 1) % 4 = 0) :
    (3 * n + 1) / 4 < n := by
  omega

/-- **Точный разрыв монотонности.** Существуют сколь угодно большие `n`, для которых сжатый
    odd-шаг РАСТИТ высоту (`n ≡ 1 mod 4` ⟹ `3n+1 ≡ 4·? + ...`). Значит НЕТ монотонной `log₂`-высоты:
    Collatz — двигатель с ограниченным топливом, но БЕЗ Lyapunov. -/
theorem no_monotone_height : ∀ N : Nat, ∃ n, N < n ∧ n % 4 = 1 ∧ n < (3 * n + 1) / 2 := by
  intro N
  refine ⟨4 * N + 5, by omega, by omega, by omega⟩

/-- **Топливо ограничено (баланс шага).** Каждый сжатый odd-шаг `n ↦ (3n+1)/2^k` тратит `k`
    делений на один впрыск (`×3+1`). Баланс в ед. `log₂`: `Δ = log₂3 − k`. Чистая алгебра: при
    `k ≥ 2` баланс отрицателен (`log₂3 < 2`), при `k = 1` — положителен. Среднее `k = 2`
    (геометрическое распределение) ⟹ средний баланс `log₂3 − 2 < 0` (сжатие). -/
theorem fuel_balance_sign : (3 : Nat) < 4 ∧ ¬ ((3 : Nat) < 2) := by omega

end EuclidsPath.Collatz.Fuel

import Mathlib

namespace EuclidsPath

/-- Пара простых-близнецов с младшим членом `p`: простые `p` и `p+2`. -/
def IsTwinPair (p : ℕ) : Prop := p.Prime ∧ (p + 2).Prime

/-- Множество младших членов пар близнецов. -/
def TwinLowers : Set ℕ := { p | IsTwinPair p }


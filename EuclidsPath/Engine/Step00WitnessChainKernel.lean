/-- The gap bound at scale 19 on all of ℕ: `G(19) ≤ 51` (witness chain + periodicity). -/
theorem cleanGapBound_19 : CleanGapBound 19 51 :=
  cleanGapBound_of_witnessChain (by norm_num) cover_19 witnessChain_19

/-- The wall instance at 19: `CleanGapBound 19 ⌊19²/7⌋`.  HONESTY CORRECTION: `51` is the
    greedy chain STEP, not the gap — the true gap is `G(19) = 25` (ledger L30, ratio ≈ 0.49);
    an earlier docstring wrongly claimed the margin was exact/tight.  (`⌊19²/14⌋ = 25` IS
    genuinely tight — the two-regime observation, see the Sharp wall.) -/
theorem twinJacobsthal_at_19 : CleanGapBound 19 (19 ^ 2 / 7) :=
  cleanGapBound_mono cleanGapBound_19 (by norm_num)

/-! ### Twin windows below the sieve horizon (kernel-free bridge) -/

/-- **Below the `A²` horizon the gap bound plants TWINS, not just clean centers**: if the
    whole window `(k, k+L]` sits under the sieve horizon (`6(k+L)+1 < A²`), the clean
    center provided by `CleanGapBound A L` has both wings prime (`sink_is_twin`). -/
theorem twin_gap_below_wall {A L : ℕ} (hbound : CleanGapBound A L) (h2 : 2 ≤ A)
    {k : ℕ} (hk : 6 * (k + L) + 1 < A * A) :
    ∃ m : ℕ, k < m ∧ m ≤ k + L ∧ TwinCenterZ m := by
  obtain ⟨m, hkm, hmL, hclean⟩ := hbound k
  exact ⟨m, hkm, hmL, sink_is_twin (by omega) (by omega) (by omega) (by omega) hclean⟩

/-- Concrete instance at `A = 13`: every window `(k, k+11]` with `k ≤ 16` contains a twin
    center (`6(k+11)+1 < 169`). -/
theorem twin_in_window_13 {k : ℕ} (hk : 6 * (k + 11) + 1 < 13 * 13) :
    ∃ m : ℕ, k < m ∧ m ≤ k + 11 ∧ TwinCenterZ m :=
  twin_gap_below_wall cleanGapBound_13 (by norm_num) hk

/-- Concrete instance at `A = 17`: every window `(k, k+41]` with `k ≤ 6` contains a twin
    center (`6(k+41)+1 < 289`). -/
theorem twin_in_window_17 {k : ℕ} (hk : 6 * (k + 41) + 1 < 17 * 17) :
    ∃ m : ℕ, k < m ∧ m ≤ k + 41 ∧ TwinCenterZ m :=
  twin_gap_below_wall cleanGapBound_17 (by norm_num) hk

